{
  "name": "karaoke-shake",
  "version": "1.0.0",
  "description": "Gerenciador de fila para karaoke",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.karaoke.shake",
    "productName": "Karaoke Shake",
    "win": {
      "target": "nsis",
      "icon": "src/assets/icon.ico"
    },
    "files": [
      "main.js",
      "src/**/*"
    ]
  }
}
