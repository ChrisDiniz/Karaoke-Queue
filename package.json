{
  "name": "karaoke-queue",
  "version": "1.0.0",
  "description": "Fair queue manager for karaoke venues",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.karaoke.queue",
    "productName": "Karaoke Queue",
    "win": {
      "target": "nsis",
      "icon": "src/assets/icon.ico"
    },
    "files": [
      "main.js",
      "src/**/*"
    ]
  }
}
